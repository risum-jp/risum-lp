---
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>リスム | 空き家・古民家のリノベーション専門</title>
  <meta name="description" content="リスムは、空き家・古民家を価値ある住まいに再生するリノベーション専門サービスです。" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&family=Noto+Serif+JP:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy:      #003686;
      --navy-d:    #002266;
      --navy-l:    #1a4fa0;
      --navy-pale: #EEF3FB;
      --accent:    #E8702A;
      --accent-l:  #F0945A;
      --accent-pale: #FEF3EB;
      --bg:        #F8F9FC;
      --bg-warm:   #F4F5F8;
      --text:      #1A1A2E;
      --text-s:    #5A6070;
      --border:    #D8DCE8;
      --white:     #ffffff;
      --font: 'Noto Sans JP', 'Hiragino Sans', sans-serif;
      --serif: 'Noto Serif JP', serif;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.8; }
    img { display: block; width: 100%; height: 100%; object-fit: cover; }
    a { text-decoration: none; }

    /* ─── HEADER ─── */
    header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      background: rgba(255,255,255,0.97); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      height: 68px; padding: 0 40px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .logo {
      font-family: var(--serif); font-size: 1.45rem; color: var(--navy);
      letter-spacing: .06em; display: flex; align-items: center; gap: 10px;
    }
    .logo-mark {
      width: 34px; height: 34px; background: var(--navy);
      border-radius: 8px; display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: .9rem; font-weight: 700;
    }
    nav { display: flex; gap: 24px; align-items: center; }
    nav a { color: var(--text-s); font-size: .85rem; font-weight: 500; transition: color .2s; }
    nav a:hover { color: var(--navy); }
    .nav-btn {
      background: var(--accent); color: #fff; padding: 10px 24px;
      border-radius: 6px; font-weight: 700; font-size: .85rem;
      transition: all .15s; display: flex; align-items: center; gap: 6px;
    }
    .nav-btn::after { content: '→'; }
    .nav-btn:hover { background: #D05E1A; }

    /* ─── HERO SLIDER ─── */
    .hero {
      margin-top: 68px; position: relative;
      height: calc(100vh - 68px); min-height: 580px;
      overflow: hidden;
    }
    .hero-slides { position: absolute; inset: 0; }
    .hero-slide {
      position: absolute; inset: 0;
      background-size: cover; background-position: center;
      opacity: 0; animation: slideShow 15s infinite;
    }
    .hero-slide:nth-child(1) {
      background-image: url('https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=1400&q=80');
      animation-delay: 0s;
    }
    .hero-slide:nth-child(2) {
      background-image: url('https://images.unsplash.com/photo-1568605114967-8130f3a36994?w=1400&q=80');
      animation-delay: 5s;
    }
    .hero-slide:nth-child(3) {
      background-image: url('https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=1400&q=80');
      animation-delay: 10s;
    }
    @keyframes slideShow {
      0%   { opacity: 0; }
      5%   { opacity: 1; }
      30%  { opacity: 1; }
      35%  { opacity: 0; }
      100% { opacity: 0; }
    }
    .hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to right, rgba(0,30,80,.78) 0%, rgba(0,30,80,.5) 55%, rgba(0,30,80,.15) 100%);
      z-index: 1;
    }
    .hero-inner {
      position: relative; z-index: 2;
      height: 100%; max-width: 1140px; margin: 0 auto;
      padding: 0 60px;
      display: flex; flex-direction: column; justify-content: center;
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.4);
      color: #fff; font-size: .72rem; font-weight: 700;
      padding: 5px 14px; border-radius: 4px; margin-bottom: 26px;
      letter-spacing: .15em; width: fit-content;
    }
    .hero h1 {
      font-family: var(--serif);
      font-size: clamp(2rem, 4.5vw, 3.8rem);
      color: #fff; line-height: 1.4; margin-bottom: 22px;
      text-shadow: 0 2px 16px rgba(0,0,0,.3);
    }
    .hero h1 em { font-style: normal; color: #7DB8FF; }
    .hero-desc {
      color: rgba(255,255,255,.9); font-size: .97rem;
      max-width: 500px; margin-bottom: 44px; line-height: 2;
    }
    .hero-btns { display: flex; gap: 16px; flex-wrap: wrap; }
    .btn-hero-main {
      background: var(--accent); color: #fff;
      padding: 16px 40px; border-radius: 6px; font-weight: 700; font-size: 1rem;
      transition: all .15s; letter-spacing: .04em;
      display: flex; align-items: center; gap: 8px;
    }
    .btn-hero-main::after { content: '→'; font-size: 1.1rem; }
    .btn-hero-main:hover { background: #D05E1A; }
    .btn-hero-sub {
      background: transparent; color: #fff;
      padding: 16px 34px; border-radius: 6px; font-weight: 500; font-size: 1rem;
      border: 1.5px solid rgba(255,255,255,.65); transition: all .15s;
    }
    .btn-hero-sub:hover { background: rgba(255,255,255,.12); border-color: #fff; }
    .hero-dots {
      position: absolute; bottom: 30px; left: 60px; z-index: 2;
      display: flex; gap: 8px;
    }
    .hero-dot {
      width: 28px; height: 3px; background: rgba(255,255,255,.4); border-radius: 2px;
    }
    .hero-dot.active { background: var(--accent); }

    /* ─── STATS ─── */
    .stats { background: var(--navy); }
    .stats-inner {
      max-width: 960px; margin: 0 auto; padding: 0 40px;
      display: grid; grid-template-columns: repeat(3,1fr);
    }
    .stat-item {
      padding: 36px 28px; text-align: center;
      border-right: 1px solid rgba(255,255,255,.12);
    }
    .stat-item:last-child { border-right: none; }
    .stat-num {
      font-family: var(--serif); font-size: 3rem; font-weight: 700;
      color: #fff; line-height: 1;
    }
    .stat-num span { font-size: 1.5rem; color: var(--accent-l); }
    .stat-label { color: rgba(255,255,255,.55); font-size: .78rem; margin-top: 8px; letter-spacing: .08em; }

    /* ─── SECTION UTILS ─── */
    .divider { height: 1px; background: var(--border); }
    section { padding: 96px 40px; }
    .sec-inner { max-width: 1100px; margin: 0 auto; }
    .sec-label {
      font-size: .7rem; font-weight: 700; letter-spacing: .25em;
      color: var(--navy); text-transform: uppercase; margin-bottom: 10px;
      display: flex; align-items: center; gap: 8px;
    }
    .sec-label::before {
      content: ''; display: block; width: 20px; height: 2px; background: var(--navy);
    }
    .sec-title {
      font-family: var(--serif); font-size: clamp(1.5rem,2.8vw,2.2rem);
      color: var(--navy); line-height: 1.5; margin-bottom: 12px;
    }
    .sec-desc { color: var(--text-s); font-size: .93rem; max-width: 540px; }
    .sec-head { margin-bottom: 56px; }

    /* ─── APPEAL ─── */
    .appeal { background: var(--white); }
    .appeal-inner {
      display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
    }
    .appeal-img-wrap { height: 420px; border-radius: 12px; overflow: hidden; }
    .appeal-content {}
    .appeal-content .sec-label { margin-bottom: 14px; }
    .appeal-content h2 {
      font-family: var(--serif); font-size: clamp(1.5rem,2.5vw,2rem);
      color: var(--navy); line-height: 1.6; margin-bottom: 20px;
    }
    .appeal-content p { color: var(--text-s); font-size: .9rem; line-height: 2; margin-bottom: 16px; }
    .appeal-nums {
      display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 32px;
    }
    .appeal-num-item {
      background: var(--navy-pale); border-radius: 10px; padding: 18px 20px;
      border-left: 3px solid var(--navy);
    }
    .appeal-num-val {
      font-family: var(--serif); font-size: 1.8rem; font-weight: 700;
      color: var(--navy); line-height: 1;
    }
    .appeal-num-val span { font-size: 1rem; }
    .appeal-num-label { font-size: .75rem; color: var(--text-s); margin-top: 4px; }

    /* ─── CONCERNS ─── */
    .concerns { background: var(--bg-warm); }
    .concern-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 22px; }
    .concern-card {
      background: var(--white); border: 1px solid var(--border);
      border-radius: 10px; padding: 34px 28px;
      border-top: 3px solid var(--navy);
      box-shadow: 0 2px 16px rgba(0,54,134,.06); transition: transform .2s, box-shadow .2s;
    }
    .concern-card:hover { transform: translateY(-4px); box-shadow: 0 8px 28px rgba(0,54,134,.1); }
    .concern-card-num {
      font-size: .68rem; font-weight: 700; color: var(--navy);
      letter-spacing: .18em; margin-bottom: 14px;
      display: flex; align-items: center; gap: 6px;
    }
    .concern-card-num::before {
      content: ''; display: block; width: 14px; height: 2px; background: var(--navy);
    }
    .concern-card-title { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 12px; line-height: 1.6; }
    .concern-card-body { font-size: .85rem; color: var(--text-s); line-height: 1.9; }

    /* ─── FEATURES ─── */
    .features { background: var(--white); }
    .feat-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 22px; }
    .feat-card {
      border-radius: 10px; padding: 40px 30px;
      background: var(--navy-pale); border: 1px solid rgba(0,54,134,.12);
      transition: transform .2s, box-shadow .2s;
    }
    .feat-card:hover { transform: translateY(-4px); box-shadow: 0 8px 28px rgba(0,54,134,.12); }
    .feat-num {
      font-size: .68rem; font-weight: 700; color: var(--navy);
      letter-spacing: .18em; margin-bottom: 20px;
      display: flex; align-items: center; gap: 6px;
    }
    .feat-num::before {
      content: ''; display: block; width: 14px; height: 2px; background: var(--navy);
    }
    .feat-icon { font-size: 2.4rem; margin-bottom: 16px; }
    .feat-title { font-size: 1.1rem; font-weight: 700; color: var(--navy); margin-bottom: 12px; }
    .feat-body { font-size: .86rem; color: var(--text-s); line-height: 1.9; }

    /* ─── PROCESS ─── */
    .process { background: var(--bg-warm); }
    .proc-list { display: flex; flex-direction: column; gap: 0; max-width: 760px; }
    .proc-item {
      display: grid; grid-template-columns: 80px 1fr; gap: 0;
      position: relative;
    }
    .proc-left { display: flex; flex-direction: column; align-items: center; }
    .proc-num {
      width: 56px; height: 56px; border-radius: 50%;
      background: var(--navy); color: #fff;
      font-family: var(--serif); font-size: 1.15rem; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; z-index: 1;
    }
    .proc-line {
      flex: 1; width: 2px; background: var(--border); margin: 4px 0;
    }
    .proc-item:last-child .proc-line { display: none; }
    .proc-right { padding: 4px 0 40px 20px; }
    .proc-title { font-size: 1.05rem; font-weight: 700; color: var(--navy); margin-bottom: 8px; line-height: 1.5; }
    .proc-body { font-size: .86rem; color: var(--text-s); line-height: 1.9; }

    /* ─── CASES ─── */
    .cases { background: var(--white); }
    .case-grid-main {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 20px;
      margin-bottom: 20px;
    }
    .case-card-featured {
      grid-column: 1 / 2; grid-row: 1 / 3;
      border-radius: 12px; overflow: hidden;
      border: 1px solid var(--border);
      box-shadow: 0 2px 16px rgba(0,54,134,.06);
      background: var(--white);
      transition: transform .2s;
    }
    .case-card-featured:hover { transform: translateY(-4px); }
    .case-card-featured .case-img-wrap { height: 340px; }
    .case-card-sm {
      border-radius: 12px; overflow: hidden;
      border: 1px solid var(--border);
      box-shadow: 0 2px 16px rgba(0,54,134,.06);
      background: var(--white);
      transition: transform .2s;
      display: grid; grid-template-columns: 180px 1fr;
    }
    .case-card-sm:hover { transform: translateY(-4px); }
    .case-card-sm .case-img-wrap { height: 100%; min-height: 140px; }
    .case-grid-sub {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 20px;
    }
    .case-card {
      border-radius: 12px; overflow: hidden;
      border: 1px solid var(--border);
      box-shadow: 0 2px 16px rgba(0,54,134,.06);
      background: var(--white);
      transition: transform .2s;
    }
    .case-card:hover { transform: translateY(-4px); }
    .case-card .case-img-wrap { height: 180px; }
    .case-img-wrap { overflow: hidden; }
    .case-tag {
      display: inline-block; background: var(--navy); color: #fff;
      font-size: .68rem; font-weight: 700; padding: 3px 10px;
      border-radius: 3px; margin-bottom: 10px; letter-spacing: .06em;
    }
    .case-body { padding: 20px 22px 22px; }
    .case-title { font-size: .95rem; font-weight: 700; color: var(--text); margin-bottom: 8px; line-height: 1.6; }
    .case-desc { font-size: .82rem; color: var(--text-s); line-height: 1.8; margin-bottom: 12px; }
    .case-meta { display: flex; gap: 14px; font-size: .76rem; color: var(--text-s); }
    .case-meta strong { color: var(--navy); font-weight: 700; }

    /* ─── STAFF ─── */
    .staff { background: var(--bg-warm); }
    .staff-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 24px; }
    .staff-card {
      background: var(--white); border-radius: 10px; overflow: hidden;
      border: 1px solid var(--border);
      box-shadow: 0 2px 12px rgba(0,54,134,.05);
      transition: transform .2s;
    }
    .staff-card:hover { transform: translateY(-4px); }
    .staff-img-wrap { height: 240px; overflow: hidden; }
    .staff-info { padding: 18px 18px 20px; }
    .staff-role {
      font-size: .68rem; font-weight: 700; color: var(--navy);
      letter-spacing: .12em; margin-bottom: 6px;
    }
    .staff-name { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 8px; }
    .staff-desc { font-size: .78rem; color: var(--text-s); line-height: 1.8; }

    /* ─── PHOTO GRID (Instagram style) ─── */
    .photo-grid { background: var(--white); padding: 64px 0; }
    .photo-grid-head { max-width: 1100px; margin: 0 auto 32px; padding: 0 40px; }
    .photo-grid-wrap {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 3px;
    }
    .photo-cell {
      aspect-ratio: 1; overflow: hidden; position: relative; cursor: pointer;
    }
    .photo-cell img { transition: transform .4s; }
    .photo-cell:hover img { transform: scale(1.06); }
    .photo-cell-overlay {
      position: absolute; inset: 0; background: rgba(0,54,134,.45);
      display: flex; align-items: center; justify-content: center;
      opacity: 0; transition: opacity .3s;
    }
    .photo-cell:hover .photo-cell-overlay { opacity: 1; }
    .photo-cell-label {
      color: #fff; font-size: .72rem; font-weight: 700; text-align: center;
      letter-spacing: .08em;
    }

    /* ─── VOICE ─── */
    .voice { background: var(--bg-warm); }
    .voice-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 22px; }
    .voice-card {
      background: var(--white); border: 1px solid var(--border);
      border-radius: 10px; padding: 30px 26px;
      box-shadow: 0 2px 12px rgba(0,54,134,.04);
    }
    .voice-quote-icon {
      font-family: Georgia, serif; font-size: 4rem; color: var(--navy);
      line-height: .7; margin-bottom: 12px; opacity: .15; font-weight: 700;
    }
    .voice-stars { color: #F5A623; font-size: .9rem; letter-spacing: 2px; margin-bottom: 14px; }
    .voice-text { font-size: .87rem; color: var(--text); line-height: 1.95; margin-bottom: 22px; }
    .voice-sep { height: 1px; background: var(--border); margin-bottom: 18px; }
    .voice-author { display: flex; align-items: center; gap: 14px; }
    .voice-avatar {
      width: 44px; height: 44px; border-radius: 50%; flex-shrink: 0;
      background: var(--navy-pale); border: 2px solid var(--border);
      display: flex; align-items: center; justify-content: center; font-size: 1.1rem;
    }
    .voice-name { font-weight: 700; font-size: .87rem; color: var(--text); }
    .voice-info { font-size: .73rem; color: var(--text-s); margin-top: 3px; }

    /* ─── FAQ ─── */
    .faq { background: var(--white); }
    .faq-wrap { max-width: 720px; margin: 0 auto; }
    .faq-item {
      border-bottom: 1px solid var(--border); padding: 28px 0;
    }
    .faq-q {
      font-weight: 700; font-size: .97rem; color: var(--text);
      display: flex; gap: 14px; align-items: flex-start; margin-bottom: 12px; line-height: 1.6;
    }
    .faq-q-badge {
      background: var(--navy); color: #fff; font-size: .7rem; font-weight: 700;
      width: 26px; height: 26px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px;
    }
    .faq-a { font-size: .87rem; color: var(--text-s); line-height: 1.95; padding-left: 40px; }

    /* ─── CTA ─── */
    .cta {
      position: relative; overflow: hidden;
      background: url('https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1400&q=80') center/cover no-repeat;
    }
    .cta-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(0,34,102,.92) 0%, rgba(0,54,134,.85) 100%);
    }
    .cta-inner {
      position: relative; z-index: 1;
      max-width: 800px; margin: 0 auto; text-align: center; padding: 0 40px;
    }
    .cta .sec-label { color: rgba(255,255,255,.7); justify-content: center; }
    .cta .sec-label::before { background: rgba(255,255,255,.5); }
    .cta .sec-title { color: #fff; text-align: center; }
    .cta-desc { color: rgba(255,255,255,.8); font-size: .95rem; margin: 0 auto 40px; max-width: 520px; line-height: 2; }
    .cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .btn-cta-main {
      background: var(--accent); color: #fff;
      padding: 18px 48px; border-radius: 6px; font-weight: 700; font-size: 1rem;
      transition: all .15s; letter-spacing: .04em;
      display: flex; align-items: center; gap: 8px;
    }
    .btn-cta-main::after { content: '→'; font-size: 1.1rem; }
    .btn-cta-main:hover { background: #D05E1A; }
    .btn-cta-sub {
      background: transparent; color: #fff;
      padding: 18px 38px; border-radius: 6px; font-weight: 500; font-size: 1rem;
      border: 1.5px solid rgba(255,255,255,.6); transition: all .15s;
    }
    .btn-cta-sub:hover { border-color: #fff; background: rgba(255,255,255,.1); }
    .cta-note { margin-top: 22px; font-size: .74rem; color: rgba(255,255,255,.5); }

    /* ─── FOOTER ─── */
    footer {
      background: var(--navy-d); color: rgba(255,255,255,.6);
      padding: 64px 40px 36px;
    }
    .footer-inner { max-width: 1100px; margin: 0 auto; }
    .footer-top {
      display: grid; grid-template-columns: 1.8fr 1fr 1fr 1fr; gap: 52px;
      padding-bottom: 48px; border-bottom: 1px solid rgba(255,255,255,.1); margin-bottom: 32px;
    }
    .footer-logo {
      font-family: var(--serif); font-size: 1.7rem; color: #fff; margin-bottom: 14px;
      display: flex; align-items: center; gap: 10px;
    }
    .footer-logo-mark {
      width: 36px; height: 36px; background: var(--accent);
      border-radius: 8px; display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: .9rem; font-weight: 700;
    }
    .footer-about { font-size: .82rem; line-height: 2; }
    .footer-col h4 { color: rgba(255,255,255,.85); font-size: .78rem; font-weight: 700; margin-bottom: 16px; letter-spacing: .12em; }
    .footer-col ul { list-style: none; }
    .footer-col li { margin-bottom: 10px; }
    .footer-col a { color: rgba(255,255,255,.45); font-size: .82rem; transition: color .2s; }
    .footer-col a:hover { color: var(--accent-l); }
    .footer-bottom { display: flex; justify-content: space-between; font-size: .75rem; }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
      .appeal-inner { grid-template-columns: 1fr; }
      .appeal-img-wrap { height: 280px; }
      .staff-grid { grid-template-columns: repeat(2,1fr); }
      .case-grid-main { grid-template-columns: 1fr; }
      .case-card-featured { grid-column: 1; grid-row: auto; }
      .case-card-sm { grid-template-columns: 1fr; }
      .case-card-sm .case-img-wrap { height: 180px; }
